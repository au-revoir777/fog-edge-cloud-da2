        "configurationVersion": 0,
        "configuration": {
          "severity": "WARNING",
          "alarmType": "WARD_ANOMALY",
          "scriptLang": "JS",
          "alarmDetailsBuildJs": "var d = {};\nd.active_devices = msg.active_devices_in_window;\nd.ward_anomaly_reason = msg.ward_anomaly_reason;\nd.fog_node = msg.fog_node_id;\nd.fog_confirmed_severity = msg.fog_confirmed_severity;\nd.note = 'Fog gateway: all 3 edge devices abnormal within 60s window';\nreturn d;",
          "useMessageAlarmData": false,
          "overwriteAlarmDetails": true,
          "propagate": true,
          "propagateToOwner": true,
          "propagateToTenant": true,
          "dynamicSeverity": false
        },
        "additionalInfo": {
          "layoutX": 700,
          "layoutY": 150,
          "description": "Node 3: WARD_ANOMALY alarm — fires when ward_anomaly=1."
        }
      },
