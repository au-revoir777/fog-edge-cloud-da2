          "scriptLang": "JS",
          "jsScript": "var sc = Number(msg.fog_confirmed_severity);\nif (sc === 2) return ['severe_confirmed'];\nif (sc === 1) return ['mild_confirmed'];\nreturn ['normal_confirmed'];"
        },
        "additionalInfo": {
          "layoutX": 700,
          "layoutY": 350,
          "description": "Node 4: Route by fog_confirmed_severity."
        }
