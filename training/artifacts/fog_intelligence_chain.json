        "debugSettings": null,
        "singletonMode": false,
        "queueName": null,
        "configurationVersion": 0,
        "configuration": {
          "scriptLang": "JS",
          "jsScript": "var wa = msg.ward_anomaly !== undefined ? Number(msg.ward_anomaly) : 0;\nif (wa === 1) return ['ward_anomaly'];\nreturn ['no_anomaly'];"
        },
        "additionalInfo": {
          "layoutX": 500,
          "layoutY": 300,
          "description": "Node 2: Route ward_anomaly FIRST — directly after save, before severity branching. This guarantees every message reaches this check regardless of alarm node output labels."
        }
      },
